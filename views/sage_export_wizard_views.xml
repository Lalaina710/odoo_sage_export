<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sage_export_wizard_form" model="ir.ui.view">
        <field name="name">sage.export.wizard.form</field>
        <field name="model">sage.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export vers Sage 100c">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="journal_ids" widget="many2many_tags"/>
                    </group>
                </group>
                <group invisible="not export_file">
                    <div class="alert alert-info" role="alert">
                        <strong>Fichier prêt.</strong> Téléchargez le fichier puis cliquez sur
                        <strong>Confirmer</strong> pour marquer les écritures comme exportées.
                    </div>
                    <field name="export_file" filename="export_filename"/>
                    <field name="export_filename" invisible="1"/>
                    <field name="export_count" string="Écritures"/>
                </group>
                <footer>
                    <button name="action_export" string="Exporter"
                            type="object" class="btn-primary"
                            invisible="export_file"/>
                    <button name="action_confirm_export"
                            string="Confirmer l'export"
                            type="object" class="btn-success"
                            invisible="not export_file"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sage_export_wizard" model="ir.actions.act_window">
        <field name="name">Export vers Sage</field>
        <field name="res_model">sage.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_sage_export"
              name="Export vers Sage"
              parent="account.menu_finance"
              action="action_sage_export_wizard"
              sequence="99"
              groups="account.group_account_manager,account.group_account_invoice"/>

</odoo>
